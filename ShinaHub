function MM2.RoleManager.new()
    local self = setmetatable({}, MM2.RoleManager)
    self.CurrentRoles = {}
    self.RoleHistory = {}
    return self
end

function MM2.RoleManager:AssignRoles(players)
    local roles = {
        Murderer = 1,
        Sheriff = 1,
        Innocent = math.max(1, #players - 2)
    }
    
    -- If more than 8 players, add Hero
    if #players >= 8 then
        roles.Hero = 1
        roles.Innocent = roles.Innocent - 1
    end
    
    -- If more than 12 players, add Traitor
    if #players >= 12 then
        roles.Traitor = 1
        roles.Innocent = roles.Innocent - 1
    end
    
    local shuffledPlayers = {}
    for i, player in ipairs(players) do
        shuffledPlayers[i] = player
    end
    
    -- Fisher-Yates shuffle
    for i = #shuffledPlayers, 2, -1 do
        local j = math.random(i)
        shuffledPlayers[i], shuffledPlayers[j] = shuffledPlayers[j], shuffledPlayers[i]
    end
    
    local assignments = {}
    local index = 1
    
    -- Assign Murderer
    assignments[shuffledPlayers[index]] = MM2.Roles.MURDERER
    index = index + 1
    
    -- Assign Sheriff
    assignments[shuffledPlayers[index]] = MM2.Roles.SHERIFF
    index = index + 1
    
    -- Assign Hero if applicable
    if roles.Hero then
        assignments[shuffledPlayers[index]] = MM2.Roles.HERO
        index = index + 1
    end
    
    -- Assign Traitor if applicable
    if roles.Traitor then
        assignments[shuffledPlayers[index]] = MM2.Roles.TRAITOR
        index = index + 1
    end
    
    -- Assign remaining as Innocent
    for i = index, #shuffledPlayers do
        assignments[shuffledPlayers[i]] = MM2.Roles.INNOCENT
    end
    
    self.CurrentRoles = assignments
    return assignments
end

function MM2.RoleManager:GetPlayerRole(player)
    return self.CurrentRoles[player]
end

function MM2.RoleManager:GetRoleColor(role)
    local colors = {
        [MM2.Roles.INNOCENT] = Color3.fromRGB(0, 255, 0),
        [MM2.Roles.SHERIFF] = Color3.fromRGB(0, 0, 255),
        [MM2.Roles.MURDERER] = Color3.fromRGB(255, 0, 0),
        [MM2.Roles.HERO] = Color3.fromRGB(255, 255, 0),
        [MM2.Roles.TRAITOR] = Color3.fromRGB(255, 165, 0),
        [MM2.Roles.DETECTIVE] = Color3.fromRGB(128, 0, 128)
    }
    return colors[role] or Color3.fromRGB(255, 255, 255)
end

