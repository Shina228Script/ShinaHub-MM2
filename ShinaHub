function MM2.QuestSystem:UpdateQuestProgress(player, questType, amount)
    if not self.PlayerQuests[player.UserId] then
        self.PlayerQuests[player.UserId] = {
            DailyProgress = {},
            WeeklyProgress = {},
            CompletedDaily = {},
            CompletedWeekly = {}
        }
    end
    
    local playerQuests = self.PlayerQuests[player.UserId]
    
    -- Check daily quests
    for _, quest in ipairs(self.DailyQuests) do
        if quest.Type == questType and not playerQuests.CompletedDaily[quest.Id] then
            playerQuests.DailyProgress[quest.Id] = (playerQuests.DailyProgress[quest.Id] or 0) + amount
            
            if playerQuests.DailyProgress[quest.Id] >= quest.Required then
                playerQuests.CompletedDaily[quest.Id] = true
                self:CompleteQuest(player, quest, "Daily")
            end
        end
    end
    
    -- Check weekly quests
    for _, quest in ipairs(self.WeeklyQuests) do
        if quest.Type == questType and not playerQuests.CompletedWeekly[quest.Id] then
            playerQuests.WeeklyProgress[quest.Id] = (playerQuests.WeeklyProgress[quest.Id] or 0) + amount
            
            if playerQuests.WeeklyProgress[quest.Id] >= quest.Required then
                playerQuests.CompletedWeekly[quest.Id] = true
                self:CompleteQuest(player, quest, "Weekly")
            end
        end
    end
end

function MM2.QuestSystem:CompleteQuest(player, quest, questType)
    -- Give rewards
    if quest.Rewards.Coins then
        MM2.DataManager:GiveCoins(player, quest.Rewards.Coins)
    end
    
    if quest.Rewards.XP then
        MM2.DataManager:AddXP(player, quest.Rewards.XP)
    end
    
    if quest.Rewards.Gems then
        MM2.DataManager:GiveGems(player, quest.Rewards.Gems)
    end
    
    -- Notify player
    -- In production, send notification to player
    print(player.Name .. " completed " .. questType .. " quest: " .. quest.Name)
end

