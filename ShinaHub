function MM2.TradingSystem:CreateTrade(player1, player2)
    local tradeId = #self.ActiveTrades + 1
    
    self.ActiveTrades[tradeId] = {
        Id = tradeId,
        Player1 = player1,
        Player2 = player2,
        Player1Items = {},
        Player2Items = {},
        Player1Coins = 0,
        Player2Coins = 0,
        Player1Confirmed = false,
        Player2Confirmed = false,
        Status = "Pending",
        CreatedAt = os.time()
    }
    
    return tradeId
end

function MM2.TradingSystem:AddItemToTrade(tradeId, player, itemId, itemType)
    local trade = self.ActiveTrades[tradeId]
    if not trade then
        return false, "Trade not found"
    end
    
    if player == trade.Player1 then
        table.insert(trade.Player1Items, {Id = itemId, Type = itemType})
    elseif player == trade.Player2 then
        table.insert(trade.Player2Items, {Id = itemId, Type = itemType})
    else
        return false, "Player not in trade"
    end
    
    return true, "Item added"
end

function MM2.TradingSystem:AddCoinsToTrade(tradeId, player, amount)
    local trade = self.ActiveTrades[tradeId]
    if not trade then
        return false, "Trade not found"
    end
    
    if amount < 0 then
        return false, "Invalid amount"
    end
    
    if player == trade.Player1 then
        trade.Player1Coins = trade.Player1Coins + amount
    elseif player == trade.Player2 then
        trade.Player2Coins = trade.Player2Coins + amount
    else
        return false, "Player not in trade"
    end
    
    return true, "Coins added"
end

function MM2.TradingSystem:ConfirmTrade(tradeId, player)
    local trade = self.ActiveTrades[tradeId]
    if not trade then
        return false, "Trade not found"
    end
    
    if player == trade.Player1 then
        trade.Player1Confirmed = true
    elseif player == trade.Player2 then
        trade.Player2Confirmed = true
    else
        return false, "Player not in trade"
    end
    
    -- Check if both confirmed
    if trade.Player1Confirmed and trade.Player2Confirmed then
        return self:ExecuteTrade(tradeId)
    end
    
    return true, "Waiting for other player"
end

function MM2.TradingSystem:ExecuteTrade(tradeId)
    local trade = self.ActiveTrades[tradeId]
    if not trade then
        return false, "Trade not found"
    end
    
    -- Validate items
    local p1Data = MM2.DataManager:LoadData(trade.Player1)
    local p2Data = MM2.DataManager:LoadData(trade.Player2)
    
    if not p1Data or not p2Data then
        return false, "Player data not found"
    end
    
    -- Check coins
    if p1Data.Coins < trade.Player1Coins then
        return false, "Player1 has insufficient coins"
    end
    if p2Data.Coins < trade.Player2Coins then
        return false, "Player2 has insufficient coins"
    end
    
    -- Execute transfer
    -- Transfer Player1's items to Player2
    for _, item in ipairs(trade.Player1Items) do
        if item.Type == "Weapon" then
            -- Remove from P1
            for i, weaponId in ipairs(p1Data.UnlockedWeapons) do
                if weaponId == item.Id then
                    table.remove(p1Data.UnlockedWeapons, i)
                    break
                end
            end
            -- Add to P2
            table.insert(p2Data.UnlockedWeapons, item.Id)
        elseif item.Type == "Effect" then
            -- Remove from P1
            for i, effectId in ipairs(p1Data.UnlockedEffects) do
                if effectId == item.Id then
                    table.remove(p1Data.UnlockedEffects, i)
                    break
                end
            end
            -- Add to P2
            table.insert(p2Data.UnlockedEffects, item.Id)
        end
    end
    
    -- Transfer Player2's items to Player1
    for _, item in ipairs(trade.Player2Items) do
        if item.Type == "Weapon" then
            -- Remove from P2
            for i, weaponId in ipairs(p2Data.UnlockedWeapons) do
                if weaponId == item.Id then
                    table.remove(p2Data.UnlockedWeapons, i)
                    break
                end
            end
            -- Add to P1
            table.insert(p1Data.UnlockedWeapons, item.Id)
        elseif item.Type == "Effect" then
            -- Remove from P2
            for i, effectId in ipairs(p2Data.UnlockedEffects) do
                if effectId == item.Id then
                    table.remove(p2Data.UnlockedEffects, i)
                    break
                end
            end
            -- Add to P1
            table.insert(p1Data.UnlockedEffects, item.Id)
        end
    end
    
    -- Transfer coins
    p1Data.Coins = p1Data.Coins - trade.Player1Coins
    p2Data.Coins = p2Data.Coins + trade.Player1Coins
    p2Data.Coins = p2Data.Coins - trade.Player2Coins
    p1Data.Coins = p1Data.Coins + trade.Player2Coins
    
    -- Update trade status
    trade.Status = "Completed"
    trade.CompletedAt = os.time()
    
    -- Record trade history
    table.insert(self.TradeHistory, {
        TradeId = tradeId,
        Player1 = trade.Player1.Name,
        Player2 = trade.Player2.Name,
        Player1Items = trade.Player1Items,
        Player2Items = trade.Player2Items,
        Player1Coins = trade.Player1Coins,
        Player2Coins = trade.Player2Coins,
        Time = os.time()
    })
    
    return true, "Trade completed"
end

