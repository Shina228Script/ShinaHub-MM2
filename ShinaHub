function MM2.ShopSystem:RefreshDailyItems()
    self.DailyItems = {}
    local availableItems = {}
    
    for id, item in pairs(self.Items) do
        if item.currency == "Coins" or item.currency == "Gems" then
            table.insert(availableItems, item)
        end
    end
    
    -- Select 6 random daily items
    for i = 1, math.min(6, #availableItems) do
        local index = math.random(1, #availableItems)
        table.insert(self.DailyItems, availableItems[index])
        table.remove(availableItems, index)
    end
end

function MM2.ShopSystem:PurchaseItem(player, itemId)
    local item = self.Items[itemId]
    if not item then
        return false, "Item not found"
    end
    
    local playerData = MM2.DataManager:LoadData(player)
    if not playerData then
        return false, "Player data not found"
    end
    
    -- Check if player can afford
    local canAfford = false
    if item.currency == "Coins" then
        canAfford = playerData.Coins >= item.price
    elseif item.currency == "Gems" then
        canAfford = playerData.Gems >= item.price
    elseif item.currency == "Robux" then
        -- In production, check Robux balance
        canAfford = true
    end
    
    if not canAfford then
        return false, "Insufficient funds"
    end
    
    -- Process purchase
    if item.currency == "Coins" then
        playerData.Coins = playerData.Coins - item.price
    elseif item.currency == "Gems" then
        playerData.Gems = playerData.Gems - item.price
    end
    
    -- Add item to inventory
    if item.type == "Weapon" then
        table.insert(playerData.UnlockedWeapons, item.weaponId)
    elseif item.type == "Effect" then
        table.insert(playerData.UnlockedEffects, item.effectId)
    elseif item.type == "Crate" then
        table.insert(playerData.Inventory, {
            Type = "Crate",
            Id = item.crateId,
            Name = item.name
        })
    end
    
    -- Record purchase
    table.insert(self.PurchaseHistory, {
        Player = player.Name,
        UserId = player.UserId,
        ItemId = itemId,
        ItemName = item.name,
        Price = item.price,
        Currency = item.currency,
        Time = os.time()
    })
    
    -- Update sales data
    if not self.SalesData[itemId] then
        self.SalesData[itemId] = 0
    end
