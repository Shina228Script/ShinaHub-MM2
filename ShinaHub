function MM2.Matchmaking.new()
    local self = setmetatable({}, MM2.Matchmaking)
    self.Queue = {}
    self.ActiveGames = {}
    self.MatchHistory = {}
    self.MaxPlayersPerGame = 12
    self.MinPlayersPerGame = 4
    self.QueueCheckInterval = 5
    return self
end

function MM2.Matchmaking:JoinQueue(player)
    -- Check if already in queue
    for i, entry in ipairs(self.Queue) do
        if entry.Player == player then
            return false, "Already in queue"
        end
    end
    
    -- Check if in game
    for _, game in pairs(self.ActiveGames) do
        for _, p in ipairs(game.Players) do
            if p == player then
                return false, "Already in a game"
            end
        end
    end
    
    local playerData = MM2.DataManager:LoadData(player)
    local skillRating = self:CalculateSkillRating(playerData)
    
    table.insert(self.Queue, {
        Player = player,
        SkillRating = skillRating,
        JoinTime = os.time(),
        Priority = 0
    })
    
    return true, "Added to queue"
end

function MM2.Matchmaking:LeaveQueue(player)
    for i, entry in ipairs(self.Queue) do
        if entry.Player == player then
            table.remove(self.Queue, i)
            return true, "Removed from queue"
        end
    end
    
    return false, "Not in queue"
end

function MM2.Matchmaking:CalculateSkillRating(playerData)
    if not playerData then return 1000 end
    
    local rating = 1000
    rating = rating + (playerData.Level * 10)
    rating = rating + (playerData.Stats.Wins * 5)
    rating = rating + (playerData.Stats.Kills * 2)
    rating = rating - (playerData.Stats.Deaths * 1)
    
    return math.max(0, rating)
end

function MM2.Matchmaking:TryCreateGame()
    if #self.Queue < self.MinPlayersPerGame then
        return false, "Not enough players"
    end
    
    -- Sort by wait time
    table.sort(self.Queue, function(a, b)
        return a.JoinTime < b.JoinTime
    end)
    
    local players = {}
    local playerCount = math.min(self.MaxPlayersPerGame, #self.Queue)
    
    for i = 1, playerCount do
        table.insert(players, self.Queue[1].Player)
        table.remove(self.Queue, 1)
    end
    
    -- Create new game
    local gameId = #self.ActiveGames + 1
    self.ActiveGames[gameId] = {
        Id = gameId,
        Players = players,
        Status = "Starting",
        CreatedAt = os.time(),
        Map = MM2.Maps[math.random(1, #MM2.Maps)]
    }
    
    return true, gameId, players
end

