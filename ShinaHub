function MM2.FriendSystem:SendFriendRequest(sender, receiver)
    if not self.FriendRequests[receiver.UserId] then
        self.FriendRequests[receiver.UserId] = {}
    end
    
    -- Check if already friends
    if self.Friends[sender.UserId] and self.Friends[sender.UserId][receiver.UserId] then
        return false, "Already friends"
    end
    
    -- Check if request already sent
    for _, request in ipairs(self.FriendRequests[receiver.UserId]) do
        if request.Sender == sender.UserId then
            return false, "Request already sent"
        end
    end
    
    table.insert(self.FriendRequests[receiver.UserId], {
        Sender = sender.UserId,
        SenderName = sender.Name,
        Time = os.time()
    })
    
    return true, "Friend request sent"
end

function MM2.FriendSystem:AcceptFriendRequest(receiver, sender)
    if not self.FriendRequests[receiver.UserId] then
        return false, "No requests"
    end
    
    for i, request in ipairs(self.FriendRequests[receiver.UserId]) do
        if request.Sender == sender.UserId then
            table.remove(self.FriendRequests[receiver.UserId], i)
            
            -- Add to friends list
            if not self.Friends[receiver.UserId] then
                self.Friends[receiver.UserId] = {}
            end
            if not self.Friends[sender.UserId] then
                self.Friends[sender.UserId] = {}
            end
            
            self.Friends[receiver.UserId][sender.UserId] = {
                FriendSince = os.time(),
                Name = sender.Name
            }
            self.Friends[sender.UserId][receiver.UserId] = {
                FriendSince = os.time(),
                Name = receiver.Name
            }
            
            return true, "Friend added"
        end
    end
    
    return false, "Request not found"
end

function MM2.FriendSystem:RemoveFriend(player, friend)
    if self.Friends[player.UserId] then
        self.Friends[player.UserId][friend.UserId] = nil
    end
    
    if self.Friends[friend.UserId] then
        self.Friends[friend.UserId][player.UserId] = nil
    end
    
    return true, "Friend removed"
end

function MM2.FriendSystem:CreateParty(leader)
    if self.Parties[leader.UserId] then
        return false, "Already have a party"
    end
    
    self.Parties[leader.UserId] = {
        Leader = leader,
        Members = {[leader.UserId] = leader},
        CreatedAt = os.time(),
        Settings = {
            Public = true,
            MaxMembers = 8
        }
    }
    
    return true, "Party created"
end

function MM2.FriendSystem:InviteToParty(inviter, player)
    if not self.Parties[inviter.UserId] then
        return false, "No party"
    end
    
    local party = self.Parties[inviter.UserId]
    
    if #party.Members >= party.Settings.MaxMembers then
        return false, "Party is full"
    end
    
    if not self.PartyInvites[player.UserId] then
        self.PartyInvites[player.UserId] = {}
    end
    
    table.insert(self.PartyInvites[player.UserId], {
        Inviter = inviter.UserId,
        InviterName = inviter.Name,
        Time = os.time()
    })
    
    return true, "Invite sent"
end

function MM2.FriendSystem:JoinParty(player, inviter)
    if not self.Parties[inviter.UserId] then
        return false, "Party not found"
    end
    
    if not self.PartyInvites[player.UserId] then
        return false, "No invites"
    end
    
    local hasInvite = false
    for i, invite in ipairs(self.PartyInvites[player.UserId]) do
        if invite.Inviter == inviter.UserId then
            table.remove(self.PartyInvites[player.UserId], i)
            hasInvite = true
            break
        end
    end
    
    if not hasInvite then
        return false, "No invite from this player"
    end
    
    self.Parties[inviter.UserId].Members[player.UserId] = player
    return true, "Joined party"
end

