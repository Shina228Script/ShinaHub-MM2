function MM2.AchievementSystem:CheckAchievements(player, data)
    if not self.PlayerAchievements[player.UserId] then
        self.PlayerAchievements[player.UserId] = {}
    end
    
    local earned = {}
    
    for id, achievement in pairs(self.Achievements) do
        if not self.PlayerAchievements[player.UserId][id] then
            local value = 0
            
            if achievement.Type == "Kills" then
                value = data.Stats.Kills
            elseif achievement.Type == "Wins" then
                value = data.Stats.Wins
            elseif achievement.Type == "SheriffWins" then
                value = data.Stats.SheriffWins
            elseif achievement.Type == "MurdererWins" then
                value = data.Stats.MurdererWins
            elseif achievement.Type == "InnocentWins" then
                value = data.Stats.InnocentWins
            elseif achievement.Type == "Level" then
                value = data.Level
            elseif achievement.Type == "Coins" then
                value = data.Coins
            elseif achievement.Type == "BestStreak" then
                value = data.Stats.BestStreak
            elseif achievement.Type == "Weapons" then
                value = #data.UnlockedWeapons
            elseif achievement.Type == "Trades" then
                value = data.Stats.Trades or 0
            elseif achievement.Type == "Crates" then
                value = data.Stats.CratesOpened or 0
            end
            
            if value >= achievement.Requirement then
                self.PlayerAchievements[player.UserId][id] = {
                    Earned = true,
                    Date = os.time()
                }
                
                -- Give reward
                if achievement.Reward.Type == "Coins" then
                    MM2.DataManager:GiveCoins(player, achievement.Reward.Amount)
                elseif achievement.Reward.Type == "Gems" then
                    MM2.DataManager:GiveGems(player, achievement.Reward.Amount)
                end
                
                table.insert(earned, {
                    Id = id,
                    Name = achievement.Name,
                    Description = achievement.Description,
                    Reward = achievement.Reward
                })
            end
        end
    end
    
    return earned
end

