function MM2.ReportSystem:SubmitReport(reporter, reportedPlayer, categoryId, description)
    if not self.ReportCategories[categoryId] then
        return false, "Invalid category"
    end
    
    -- Check for spam reports
    if self:GetReportCount(reporter, reportedPlayer) > 3 then
        return false, "Too many reports against this player"
    end
    
    local reportId = #self.Reports + 1
    
    self.Reports[reportId] = {
        Id = reportId,
        Reporter = reporter.Name,
        ReporterId = reporter.UserId,
        ReportedPlayer = reportedPlayer.Name,
        ReportedId = reportedPlayer.UserId,
        Category = self.ReportCategories[categoryId].Name,
        Description = description,
        Time = os.time(),
        Status = "Pending",
        Evidence = {}
    }
    
    return true, "Report submitted", reportId
end

function MM2.ReportSystem:GetReportCount(reporter, reportedPlayer)
    local count = 0
    local currentTime = os.time()
    
    for _, report in pairs(self.Reports) do
        if report.ReporterId == reporter.UserId and 
           report.ReportedId == reportedPlayer.UserId and
           currentTime - report.Time < 86400 then -- 24 hours
            count = count + 1
        end
    end
    
    return count
end

function MM2.ReportSystem:ProcessReport(reportId, action, notes)
    if not self.Reports[reportId] then
        return false, "Report not found"
    end
    
    self.Reports[reportId].Status = "Processed"
    self.Reports[reportId].Action = action
    self.Reports[reportId].Notes = notes
    self.Reports[reportId].ProcessedTime = os.time()
    
    self.ProcessedReports[reportId] = self.Reports[reportId]
    
    return true, "Report processed"
end

