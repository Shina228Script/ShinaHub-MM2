MM2.CombatSystem = {}
MM2.CombatSystem.__index = MM2.CombatSystem

function MM2.CombatSystem.new()
    local self = setmetatable({}, MM2.CombatSystem)
    self.DamageMultipliers = {}
    self.KillEffects = {}
    self.CombatLog = {}
    self.LastAttackTime = {}
    return self
end

function MM2.CombatSystem:Attack(attacker, target, weapon)
    local currentTime = tick()
    
    -- Check cooldown
    if self.LastAttackTime[attacker] then
        local timeSinceLastAttack = currentTime - self.LastAttackTime[attacker]
        if timeSinceLastAttack < weapon.cooldown then
            return false, "On cooldown"
        end
    end
    
    -- Check range
    if attacker.Character and target.Character then
        local distance = (attacker.Character.HumanoidRootPart.Position - 
                         target.Character.HumanoidRootPart.Position).Magnitude
        if distance > weapon.range then
            return false, "Out of range"
        end
    end
    
    -- Apply damage
    local damage = weapon.damage
    if self.DamageMultipliers[attacker] then
        damage = damage * self.DamageMultipliers[attacker]
    end
    
    -- Apply armor reduction
    if target.Armor and target.Armor > 0 then
        damage = damage * (1 - target.Armor / 100)
        target.Armor = math.max(0, target.Armor - 10)
    end
    
    -- Apply damage to target
    if target.Character and target.Character.Humanoid then
        target.Character.Humanoid.Health = math.max(0, 
            target.Character.Humanoid.Health - damage)
    end
    
    -- Update last attack time
    self.LastAttackTime[attacker] = currentTime
    
    -- Log combat
    table.insert(self.CombatLog, {
        Time = currentTime,
        Attacker = attacker.Name,
        Target = target.Name,
        Weapon = weapon.name,
        Damage = damage
    })
    
    -- Check for kill
    if target.Character and target.Character.Humanoid.Health <= 0 then
        self:HandleKill(attacker, target)
        return true, "Kill"
    end
    
    return true, "Hit"
end

function MM2.CombatSystem:HandleKill(killer, victim)
    -- Trigger kill effects
    if self.KillEffects[killer] then
        self:PlayKillEffect(killer, victim)
    end
    
    -- Update stats
    if MM2.DataManager then
        local killerData = MM2.DataManager:LoadData(killer)
        if killerData then
            killerData.Stats.Kills = (killerData.Stats.Kills or 0) + 1
            killerData.Stats.CurrentStreak = (killerData.Stats.CurrentStreak or 0) + 1
            if killerData.Stats.CurrentStreak > (killerData.Stats.BestStreak or 0) then
                killerData.Stats.BestStreak = killerData.Stats.CurrentStreak
            end
        end
        
        local victimData = MM2.DataManager:LoadData(victim)
        if victimData then
            victimData.Stats.Deaths = (victimData.Stats.Deaths or 0) + 1
            victimData.Stats.CurrentStreak = 0
        end
    end
    
    -- Broadcast kill
    self:BroadcastKill(killer, victim)
end

function MM2.CombatSystem:BroadcastKill(killer, victim)
    -- Create kill message
    local killMessage = killer.Name .. " has eliminated " .. victim.Name
    if self.KillEffects[killer] then
        killMessage = killMessage .. " with " .. self.KillEffects[killer].name
    end
    
    -- In production, send to all players via RemoteEvent
    print("[MM2] " .. killMessage)
end

function MM2.CombatSystem:PlayKillEffect(killer, victim)
    local effect = self.KillEffects[killer]
    if not effect then return end
    
    -- Create effect particles
    if victim.Character then
        local effectPart = Instance.new("Part")
        effectPart.Position = victim.Character.HumanoidRootPart.Position
        effectPart.Anchored = true
        effectPart.CanCollide = false
        effectPart.Size = Vector3.new(1, 1, 1)
        effectPart.Transparency = 1
        effectPart.Parent = workspace
        
        local particleEmitter = Instance.new("ParticleEmitter")
        particleEmitter.Color = ColorSequence.new(effect.color)
        particleEmitter.Rate = 100
        particleEmitter.Lifetime = NumberRange.new(0.5, 1)
        particleEmitter.Speed = NumberRange.new(5, 10)
        particleEmitter.SpreadAngle = Vector2.new(360, 360)
        particleEmitter.Parent = effectPart
        
        -- Remove after effect
        delay(2, function()
            effectPart:Destroy()
        end)
    end
end

