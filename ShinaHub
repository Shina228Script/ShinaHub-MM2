function MM2.CrateSystem:OpenCrate(player, crateId)
    local crate = self.CrateContents[crateId]
    if not crate then
        return false, "Invalid crate"
    end
    
    local playerData = MM2.DataManager:LoadData(player)
    if not playerData then
        return false, "Player data not found"
    end
    
    -- Check if player has crate
    local hasCrate = false
    for i, item in ipairs(playerData.Inventory) do
        if item.Type == "Crate" and item.Id == crateId then
            table.remove(playerData.Inventory, i)
            hasCrate = true
            break
        end
    end
    
    if not hasCrate then
        return false, "Player doesn't have this crate"
    end
    
    -- Roll for main item
    local totalChance = 0
    for _, item in ipairs(crate.Items) do
        totalChance = totalChance + item.Chance
    end
    
    local roll = math.random(1, totalChance)
    local currentChance = 0
    local selectedItem = nil
    
    for _, item in ipairs(crate.Items) do
        currentChance = currentChance + item.Chance
        if roll <= currentChance then
            selectedItem = item
            break
        end
    end
    
    local rewards = {}
    
    if selectedItem then
        if selectedItem.Type == "Weapon" then
            if not table.find(playerData.UnlockedWeapons, selectedItem.Id) then
                table.insert(playerData.UnlockedWeapons, selectedItem.Id)
                table.insert(rewards, {
                    Type = "Weapon",
                    Id = selectedItem.Id,
                    Name = MM2.Weapons[selectedItem.Id].name
                })
            else
                -- Duplicate weapon - give coins
                local coinAmount = self:GetDuplicateWeaponValue(selectedItem.Id)
                playerData.Coins = playerData.Coins + coinAmount
                table.insert(rewards, {
                    Type = "Coins",
                    Amount = coinAmount,
                    Reason = "Duplicate weapon"
                })
            end
        elseif selectedItem.Type == "Effect" then
            if not table.find(playerData.UnlockedEffects, selectedItem.Id) then
                table.insert(playerData.UnlockedEffects, selectedItem.Id)
                table.insert(rewards, {
                    Type = "Effect",
                    Id = selectedItem.Id
                })
            else
                -- Duplicate effect - give gems
                local gemAmount = 50
                playerData.Gems = playerData.Gems + gemAmount
                table.insert(rewards, {
                    Type = "Gems",
                    Amount = gemAmount,
                    Reason = "Duplicate effect"
                })
            end
        end
    end
    
    -- Roll for bonus items
    if crate.BonusItems then
        for _, bonus in ipairs(crate.BonusItems) do
            if math.random(1, 100) <= bonus.Chance then
                if bonus.Type == "Coins" then
                    playerData.Coins = playerData.Coins + bonus.Amount
                    table.insert(rewards, {
                        Type = "Coins",
                        Amount = bonus.Amount,
                        Reason = "Bonus"
                    })
                elseif bonus.Type == "Gems" then
                    playerData.Gems = playerData.Gems + bonus.Amount
                    table.insert(rewards, {
                        Type = "Gems",
                        Amount = bonus.Amount,
                        Reason = "Bonus"
                    })
                end
            end
        end
    end
    
    -- Update stats
    playerData.Stats.CratesOpened = (playerData.Stats.CratesOpened or 0) + 1
    
    return true, rewards
end

function MM2.CrateSystem:GetDuplicateWeaponValue(weaponId)
    local values = {
        [1] = 25,   -- Common
        [2] = 100,  -- Rare
        [7] = 75,   -- Rare
        [3] = 200,  -- Epic
        [8] = 250,  -- Epic
        [4] = 500,  -- Legendary
        [9] = 750,  -- Legendary
        [5] = 1500, -- Mythical
        [6] = 5000  -- Divine
    }
    return values[weaponId] or 100
end

