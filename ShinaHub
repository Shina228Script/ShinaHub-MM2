function MM2.Leaderboard:GetTopPlayers(category, limit)
    limit = limit or 10
    local sorted = {}
    
    for userId, entry in pairs(self.Entries) do
        if entry[category] then
            table.insert(sorted, {
                UserId = userId,
                Name = entry.PlayerName,
                Value = entry[category]
            })
        end
    end
    
    table.sort(sorted, function(a, b)
        return a.Value > b.Value
    end)
    
    local result = {}
    for i = 1, math.min(limit, #sorted) do
        table.insert(result, sorted[i])
    end
    
    return result
end

function MM2.Leaderboard:GetPlayerRank(player, category)
    local topPlayers = self:GetTopPlayers(category, 1000) -- Get all players
    
    for i, entry in ipairs(topPlayers) do
        if entry.UserId == player.UserId then
            return i
        end
    end
    
    return nil
end

