        -- Free tier rewards
        self.FreeTiers[tier] = {
            Tier = tier,
            XPRequired = tier * 100,
            Rewards = {}
        }
        
        -- Premium tier rewards
        self.PremiumTiers[tier] = {
            Tier = tier,
            XPRequired = tier * 100,
            Rewards = {}
        }
        
        -- Add rewards based on tier
        if tier % 5 == 0 then
            -- Every 5 tiers
            table.insert(self.FreeTiers[tier].Rewards, {
                Type = "Coins",
                Amount = tier * 50
            })
            
            table.insert(self.PremiumTiers[tier].Rewards, {
                Type = "Gems",
                Amount = tier * 2
            })
        end
        
        if tier % 10 == 0 then
            -- Every 10 tiers - weapon
            local weaponId = math.random(1, 9)
            table.insert(self.PremiumTiers[tier].Rewards, {
                Type = "Weapon",
                Id = weaponId
            })
        end
        
        if tier == 25 then
            -- Tier 25 - special effect
            table.insert(self.PremiumTiers[tier].Rewards, {
                Type = "Effect",
                Id = math.random(1, 4)
            })
        end
        
        if tier == 50 then
            -- Tier 50 - divine weapon
            table.insert(self.PremiumTiers[tier].Rewards, {
                Type = "Weapon",
                Id = 6 -- Death Scythe
            })
        end
    end
end

function MM2.SeasonPass:AddXP(player, amount)
    if not self.PlayerProgress[player.UserId] then
        self.PlayerProgress[player.UserId] = {
            CurrentTier = 1,
            CurrentXP = 0,
            Premium = false,
            ClaimedFreeRewards = {},
            ClaimedPremiumRewards = {}
        }
    end
    
    local progress = self.PlayerProgress[player.UserId]
    progress.CurrentXP = progress.CurrentXP + amount
    
    -- Check for tier up
    while progress.CurrentTier < 50 do
        local required = self.FreeTiers[progress.CurrentTier].XPRequired
        if progress.CurrentXP >= required then
            progress.CurrentXP = progress.CurrentXP - required
            progress.CurrentTier = progress.CurrentTier + 1
        else
            break
        end
    end
    
    return progress
end

function MM2.SeasonPass:ClaimReward(player, tier, isPremium)
    local progress = self.PlayerProgress[player.UserId]
    if not progress then
        return false, "No progress"
    end
    
    if progress.CurrentTier < tier then
        return false, "Tier not reached"
    end
    
    if isPremium and not progress.Premium then
        return false, "Premium required"
    end
    
    local claimedTable = isPremium and progress.ClaimedPremiumRewards or progress.ClaimedFreeRewards
    
    if claimedTable[tier] then
        return false, "Already claimed"
    end
    
    local rewards = isPremium and self.PremiumTiers[tier].Rewards or self.FreeTiers[tier].Rewards
    
    -- Give rewards
    for _, reward in ipairs(rewards) do
        if reward.Type == "Coins" then
            MM2.DataManager:GiveCoins(player, reward.Amount)
        elseif reward.Type == "Gems" then
            MM2.DataManager:GiveGems(player, reward.Amount)
        elseif reward.Type == "Weapon" then
            local playerData = MM2.DataManager:LoadData(player)
            if playerData and not table.find(playerData.UnlockedWeapons, reward.Id) then
                table.insert(playerData.UnlockedWeapons, reward.Id)
            end
        elseif reward.Type == "Effect" then
            local playerData = MM2.DataManager:LoadData(player)
            if playerData and not table.find(playerData.UnlockedEffects, reward.Id) then
                table.insert(playerData.UnlockedEffects, reward.Id)
            end
        end
    end
    
    claimedTable[tier] = true
    return true, rewards
end

