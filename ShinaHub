MM2.DataManager = {}
MM2.DataManager.__index = MM2.DataManager

function MM2.DataManager.new()
    local self = setmetatable({}, MM2.DataManager)
    self.PlayerData = {}
    self.GameStats = {}
    self.TradingData = {}
    self.InventoryData = {}
    return self
end

function MM2.DataManager:InitializePlayer(player)
    if not self.PlayerData[player.UserId] then
        self.PlayerData[player.UserId] = {
            Level = 1,
            XP = 0,
            Coins = 100,
            Gems = 0,
            Inventory = {},
            EquippedWeapon = nil,
            EquippedEffect = nil,
            Stats = {
                Wins = 0,
                Losses = 0,
                Kills = 0,
                Deaths = 0,
                SheriffWins = 0,
                MurdererWins = 0,
                InnocentWins = 0,
                TotalGames = 0,
                BestStreak = 0,
                CurrentStreak = 0
            },
            Settings = {
                MusicVolume = 50,
                SFXVolume = 50,
                ShowKillEffects = true,
                ShowParticles = true,
                AutoEquip = false
            },
            UnlockedWeapons = {1}, -- Start with default knife
            UnlockedEffects = {},
            TradingEnabled = true,
            LastSave = os.time()
        }
    end
    return self.PlayerData[player.UserId]
end

function MM2.DataManager:SaveData(player)
    local data = self.PlayerData[player.UserId]
    if data then
        data.LastSave = os.time()
        -- In production, save to DataStore
        return true
    end
    return false
end

function MM2.DataManager:LoadData(player)
    local data = self:InitializePlayer(player)
    -- In production, load from DataStore
    return data
end

function MM2.DataManager:AddXP(player, amount)
    local data = self:LoadData(player)
    data.XP = data.XP + amount
    
    local xpToLevel = data.Level * 100
    while data.XP >= xpToLevel do
        data.XP = data.XP - xpToLevel
        data.Level = data.Level + 1
        xpToLevel = data.Level * 100
        
        -- Level up rewards
        self:GiveCoins(player, data.Level * 10)
        if data.Level % 5 == 0 then
            self:GiveGems(player, 10)
        end
        if data.Level % 10 == 0 then
            -- Unlock random weapon
            local weaponIds = {}
            for id, weapon in pairs(MM2.Weapons) do
                if not table.find(data.UnlockedWeapons, id) then
                    table.insert(weaponIds, id)
                end
            end
            if #weaponIds > 0 then
                local randomWeapon = weaponIds[math.random(1, #weaponIds)]
                table.insert(data.UnlockedWeapons, randomWeapon)
            end
        end
    end
    
    return data
end

function MM2.DataManager:GiveCoins(player, amount)
    local data = self:LoadData(player)
    data.Coins = (data.Coins or 0) + amount
    return data
end

function MM2.DataManager:GiveGems(player, amount)
    local data = self:LoadData(player)
    data.Gems = (data.Gems or 0) + amount
    return data
end

