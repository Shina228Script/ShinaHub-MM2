function MM2.TeleportSystem:TeleportPlayer(player, location)
    if not self.TeleportLocations[location] then
        return false, "Invalid location"
    end
    
    local cooldownKey = player.UserId .. "_" .. location
    
    if self.Cooldowns[cooldownKey] then
        local timeSinceLast = os.time() - self.Cooldowns[cooldownKey]
        if timeSinceLast < 5 then
            return false, "Teleport on cooldown"
        end
    end
    
    local targetPosition = self.TeleportLocations[location].Position
    
    if player.Character and player.Character.HumanoidRootPart then
        player.Character.HumanoidRootPart.CFrame = CFrame.new(targetPosition)
        
        -- Add some randomness to position
        local randomX = math.random(-5, 5)
        local randomZ = math.random(-5, 5)
        player.Character.HumanoidRootPart.CFrame = CFrame.new(
            targetPosition + Vector3.new(randomX, 0, randomZ)
        )
        
        -- Update cooldown
        self.Cooldowns[cooldownKey] = os.time()
        
        -- Log teleport
        table.insert(self.TeleportHistory, {
            Player = player.Name,
            UserId = player.UserId,
            Location = location,
            Time = os.time()
        })
        
        return true, "Teleported to " .. location
    end
    
    return false, "Character not found"
end

