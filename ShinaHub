function MM2.ChatSystem:InitializeFilters()
    self.ChatFilters = {
        Profanity = true,
        Spam = true,
        Links = true,
        Caps = true
    }
end

function MM2.ChatSystem:SendMessage(player, message)
    -- Check if muted
    if self.MutedPlayers[player.UserId] then
        local muteTime = self.MutedPlayers[player.UserId]
        if os.time() < muteTime then
            return false, "You are muted"
        else
            self.MutedPlayers[player.UserId] = nil
        end
    end
    
    -- Filter message
    message = self:FilterMessage(player, message)
    
    -- Check for spam
    if self.ChatFilters.Spam then
        if self:IsSpam(player) then
            return false, "Please don't spam"
        end
    end
    
    -- Add to history
    table.insert(self.ChatHistory, {
        Player = player.Name,
        UserId = player.UserId,
        Message = message,
        Time = os.time(),
        Channel = "Global"
    })
    
    -- Keep only last 100 messages
    while #self.ChatHistory > 100 do
        table.remove(self.ChatHistory, 1)
    end
    
    -- Broadcast to all players
    -- In production, send via RemoteEvent
    
    return true, message
end

function MM2.ChatSystem:FilterMessage(player, message)
    local filteredMessage = message
    
    -- Filter links
    if self.ChatFilters.Links then
        filteredMessage = filteredMessage:gsub("https?://[%w_%.%+%-/#%%?=&]+", "[Link Removed]")
        filteredMessage = filteredMessage:gsub("www%.[%w_%.%+%-]+", "[Link Removed]")
    end
    
    -- Filter excessive caps
    if self.ChatFilters.Caps then
        local upperCount = 0
        local totalLetters = 0
        for char in filteredMessage:gmatch("%a") do
            totalLetters = totalLetters + 1
            if char:upper() == char then
                upperCount = upperCount + 1
            end
        end
        if totalLetters > 5 and upperCount / totalLetters > 0.7 then
            filteredMessage = filteredMessage:lower()
        end
    end
    
    return filteredMessage
end

function MM2.ChatSystem:IsSpam(player)
    local recentMessages = 0
    local currentTime = os.time()
    
    for i = #self.ChatHistory, 1, -1 do
        local msg = self.ChatHistory[i]
        if msg.UserId == player.UserId then
            if currentTime - msg.Time < 2 then
                recentMessages = recentMessages + 1
                if recentMessages > 3 then
                    return true
                end
            else
                break
            end
        end
    end
    
    return false
end

function MM2.ChatSystem:MutePlayer(player, duration)
    self.MutedPlayers[player.UserId] = os.time() + duration
    return true, "Player muted for " .. duration .. " seconds"
end

