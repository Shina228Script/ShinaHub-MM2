function MM2.EffectSystem:CreateEffect(effectName, position, duration)
    local template = self.EffectTemplates[effectName]
    if not template then return false end
    
    local effectPart = Instance.new("Part")
    effectPart.Name = "Effect_" .. effectName
    effectPart.Position = position
    effectPart.Anchored = true
    effectPart.CanCollide = false
    effectPart.Size = Vector3.new(0.1, 0.1, 0.1)
    effectPart.Transparency = 1
    effectPart.Parent = workspace
    
    local particleEmitter = Instance.new("ParticleEmitter")
    particleEmitter.Rate = template.Particles.Rate
    particleEmitter.Lifetime = template.Particles.Lifetime
    particleEmitter.Speed = template.Particles.Speed
    particleEmitter.Size = template.Particles.Size
    particleEmitter.Color = template.Particles.Color
    particleEmitter.SpreadAngle = Vector2.new(360, 360)
    particleEmitter.Parent = effectPart
    
    -- Optional light
    local pointLight = Instance.new("PointLight")
    pointLight.Color = template.Color
    pointLight.Range = 5
    pointLight.Brightness = 2
    pointLight.Parent = effectPart
    
    local effectId = #self.ActiveEffects + 1
    self.ActiveEffects[effectId] = {
        Id = effectId,
        Name = effectName,
        Object = effectPart,
        CreatedAt = os.time()
    }
    
    -- Remove after duration
    delay(duration or 5, function()
        if effectPart and effectPart.Parent then
            effectPart:Destroy()
        end
        self.ActiveEffects[effectId] = nil
    end)
    
    return effectId
end

