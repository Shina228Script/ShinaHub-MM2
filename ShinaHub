    return self
end

function MM2.AntiCheat:InitializeDetection()
    self.DetectionMethods = {
        SpeedHack = {
            MaxSpeed = 50,
            CheckInterval = 1,
            ViolationThreshold = 3
        },
        TeleportHack = {
            MaxDistance = 100,
            CheckInterval = 0.5,
            ViolationThreshold = 2
        },
        KillAura = {
            MaxKillsPerSecond = 2,
            CheckInterval = 5,
            ViolationThreshold = 3
        },
        InfiniteCoins = {
            MaxCoinsPerHour = 10000,
            CheckInterval = 3600,
            ViolationThreshold = 1
        }
    }
end

function MM2.AntiCheat:CheckSpeedHack(player)
    if not player.Character then return false end
    if not player.Character.HumanoidRootPart then return false end
    
    local hrp = player.Character.HumanoidRootPart
    local velocity = hrp.Velocity.Magnitude
    
    if velocity > self.DetectionMethods.SpeedHack.MaxSpeed then
        self:LogViolation(player, "SpeedHack", velocity)
        return true
    end
    
    return false
end

function MM2.AntiCheat:CheckTeleport(player, oldPosition)
    if not player.Character then return false end
    if not player.Character.HumanoidRootPart then return false end
    
    local newPosition = player.Character.HumanoidRootPart.Position
    local distance = (newPosition - oldPosition).Magnitude
    
    if distance > self.DetectionMethods.TeleportHack.MaxDistance then
        self:LogViolation(player, "TeleportHack", distance)
        return true
    end
    
    return false
end

function MM2.AntiCheat:LogViolation(player, violationType, value)
    if not self.SuspiciousActivity[player.UserId] then
        self.SuspiciousActivity[player.UserId] = {}
    end
    
    table.insert(self.SuspiciousActivity[player.UserId], {
        Type = violationType,
        Value = value,
        Time = os.time()
    })
    
    -- Check if should be banned
    local violations = self:GetViolations(player, violationType)
    local threshold = self.DetectionMethods[violationType].ViolationThreshold
    
    if violations >= threshold then
        self:BanPlayer(player, violationType)
    end
end

function MM2.AntiCheat:GetViolations(player, violationType)
    if not self.SuspiciousActivity[player.UserId] then
        return 0
    end
    
    local count = 0
    local currentTime = os.time()
    local interval = self.DetectionMethods[violationType].CheckInterval
    
    for _, violation in ipairs(self.SuspiciousActivity[player.UserId]) do
        if violation.Type == violationType and 
           (currentTime - violation.Time) < interval then
            count = count + 1
        end
    end
    
    return count
end

function MM2.AntiCheat:BanPlayer(player, reason)
    self.BannedPlayers[player.UserId] = {
        PlayerName = player.Name,
        Reason = reason,
        BanDate = os.time(),
        Duration = 7 * 24 * 60 * 60 -- 7 days
    }
    
    -- In production, add to ban list and kick player
    print("[ANTI-CHEAT] " .. player.Name .. " has been banned for: " .. reason)
end

function MM2.AntiCheat:IsBanned(player)
    if not self.BannedPlayers[player.UserId] then
        return false
    end
    
    local ban = self.BannedPlayers[player.UserId]
    local currentTime = os.time()
    
    if currentTime - ban.BanDate > ban.Duration then
        self.BannedPlayers[player.UserId] = nil
        return false
    end
    
    return true
end

